#!/usr/bin/env bash
# GoodyOS live-build config — Technology Stack
# Base: Debian Bookworm | Kernel: amd64 (hardened via sysctl + hardening-runtime)
# Desktop: KDE Plasma (from package-lists) | Build: live-build
# Run from repo root: ./auto/config

set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$REPO_ROOT"

# Ensures config/ exists and lb config is run with GoodyOS options.
# Our config/package-lists, config/hooks, config/includes stay as-is.

lb config \
	--distribution bookworm \
	--architecture amd64 \
	--archive-areas "main contrib non-free non-free-firmware" \
	--mirror-bootstrap "http://deb.debian.org/debian/" \
	--mirror-chroot "http://deb.debian.org/debian/" \
	--mirror-chroot-security "http://security.debian.org/debian-security" \
	--mirror-binary "http://deb.debian.org/debian/" \
	--mirror-binary-security "http://security.debian.org/debian-security" \
	--debootstrap-options "--variant=minbase" \
	--apt-recommends false \
	--bootloader grub-pc \
	--linux-flavours amd64 \
	--firmware-chroot true \
	--firmware-binary true \
	--memtest none \
	--win32-loader false

echo "[GoodyOS] lb config done. Technology Stack: Bookworm, amd64, KDE (from lists), nftables+UFW, Mullvad (from archive)."
