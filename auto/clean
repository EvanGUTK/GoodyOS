#!/usr/bin/env bash
# GoodyOS — clean all build artifacts
# Run: sudo ./auto/clean

set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$REPO_ROOT"

echo "[GoodyOS] Cleaning build artifacts..."
sudo lb clean
echo "[GoodyOS] Clean complete."
